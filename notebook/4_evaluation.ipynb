# =========================================

# TRAIN + EVALUATE 5 MODELS

# =========================================

for name, model in models.items():

   

    pipeline = Pipeline(stages=[assembler, model])

    fitted_model = pipeline.fit(train_sample)

    predictions = fitted_model.transform(test_df)

   

    rmse = evaluator.evaluate(predictions)

    results[name] = rmse

   

    print(f"{name} RMSE: {round(rmse, 2)}")

   

    if rmse < best_rmse:

        best_rmse = rmse

        best_model = fitted_model

        best_name = name

 

print("\nBest Baseline Model:", best_name)

 

# =========================================

#  RANDOM FOREST CROSS-VALIDATION

# =========================================

pipeline_rf = Pipeline(stages=[assembler, rf])

 

paramGrid = ParamGridBuilder() \

    .addGrid(rf.maxDepth, [3, 4]) \

    .addGrid(rf.numTrees, [4, 10]) \

    .build()

 

cv = CrossValidator(

    estimator=pipeline_rf,

    estimatorParamMaps=paramGrid,

    evaluator=evaluator,

    numFolds=3

)

 

# Sample small for safety

train_sample_small = train_df.sample(False, 0.05, seed=42)

 

param_grid = [

    {"maxDepth": 3, "numTrees": 5},

    {"maxDepth": 3, "numTrees": 10},

    {"maxDepth": 5, "numTrees": 5},

    {"maxDepth": 5, "numTrees": 10}

]

 

best_rmse = float("inf")

best_model = None

best_params = {}

 

for params in param_grid:

    rf = RandomForestRegressor(

        featuresCol="features",

        labelCol="base_passenger_fare",

        maxDepth=params["maxDepth"],

        numTrees=params["numTrees"]

    )

   

    pipeline_rf = Pipeline(stages=[assembler, rf])

    model = pipeline_rf.fit(train_sample_small)

   

    predictions = model.transform(test_df)

    rmse = evaluator.evaluate(predictions)

   

    print(f"RF maxDepth={params['maxDepth']} numTrees={params['numTrees']} RMSE={rmse:.2f}")

   

    if rmse < best_rmse:

        best_rmse = rmse

        best_model = model

        best_params = params

 

print("\nBest RF params:", best_params)

print("Best RF RMSE:", round(best_rmse, 2))

 

# =========================================

# FEATURE IMPORTANCE (RF)

# =========================================

best_rf_model = best_model.stages[-1]  

print("\nRandomForest Feature Importances:")

for feature, importance in zip(feature_cols, best_rf_model.featureImportances):

    print(f"{feature}: {importance:.4f}")

 

# =========================================

# SAVE PREDICTIONS AS GOLD TABLE

# =========================================

cv_predictions = best_model.transform(test_df)

 

gold_table = cv_predictions.groupBy("month", "hour_of_day") \

    .agg(

        F.avg("base_passenger_fare").alias("Actual_Avg_Fare"),

        F.avg("prediction").alias("Predicted_Avg_Fare"),

        F.count("*").alias("Trip_Count")

    )

 

# Save as managed table for Tableau

gold_table.write.mode("overwrite").saveAsTable("fhv_gold_table")

 

print("\n Feature importances displayed and gold table ready for Tableau.")



gold_table = spark.table("workspace.default.fhv_gold_table")


gold_table_sample = gold_table.sample(False, 0.1, seed=42)  # 10% sample 


# Convert to Pandas DataFrame

gold_pdf = gold_table_sample.toPandas()



csv_path = "/tmp/fhv_gold_table.csv"

gold_pdf.to_csv(csv_path, index=False)

 

print(f" CSV saved at {csv_path}")

display(gold_pdf.head())
