# =========================================

# DEFINE 5 ML MODELS

# =========================================

lr = LinearRegression(

    featuresCol="features",

    labelCol="base_passenger_fare"

)

 

dt = DecisionTreeRegressor(

    featuresCol="features",

    labelCol="base_passenger_fare",

    maxDepth=5

)

 

rf = RandomForestRegressor(

    featuresCol="features",

    labelCol="base_passenger_fare"

)

 

gbt = GBTRegressor(

    featuresCol="features",

    labelCol="base_passenger_fare",

    maxIter=10,

    maxDepth=5

)

 

glr = GeneralizedLinearRegression(

    featuresCol="features",

    labelCol="base_passenger_fare",

    family="gaussian"

)

 

models = {

    "LinearRegression": lr,

    "DecisionTree": dt,

    "RandomForest": rf,

    "GBT": gbt,

    "GeneralizedLinearRegression": glr

}

 

evaluator = RegressionEvaluator(

    labelCol="base_passenger_fare",

    predictionCol="prediction",

    metricName="rmse"

)

 

results = {}

best_model = None

best_rmse = float("inf")

best_name = ""

 
